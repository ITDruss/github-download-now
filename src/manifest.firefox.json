{
  "manifest_version": 3,
  "name": "GitHub Download Now",
  "version": "0.4.2",
  "description": "Adds a smart GitHub release download button, remembers downloads, and optionally watches repositories for new releases.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "https://api.github.com/*"
  ],
  "background": {
    "scripts": [
      "settings.js",
      "asset-selector.js",
      "tracker.js",
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "settings.js",
        "asset-selector.js",
        "install-guides.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{5b0a5b9e-74aa-4c0a-9b95-2ecf93f8a1df}",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "browsingActivity"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "permissions": [
    "storage",
    "alarms"
  ],
  "action": {
    "default_title": "GitHub Download Now",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "optional_permissions": [
    "notifications"
  ]
}
