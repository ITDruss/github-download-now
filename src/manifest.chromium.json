{
  "manifest_version": 3,
  "name": "GitHub Download Now",
  "version": "0.4.1",
  "description": "Adds a smart GitHub release download button, remembers downloads, and optionally watches repositories for new releases.",
  "minimum_chrome_version": "121",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "host_permissions": [
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://github.com/*"
      ],
      "js": [
        "settings.js",
        "asset-selector.js",
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "alarms"
  ],
  "action": {
    "default_title": "GitHub Download Now",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "optional_permissions": [
    "notifications"
  ]
}
